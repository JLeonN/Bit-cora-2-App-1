rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /ubicacionesCompartidas/{identificador} {
      allow create: if documentoCompartidoValido();
      allow get: if true;
      allow list, update, delete: if false;
    }

    function documentoCompartidoValido() {
      return request.resource.data.keys().hasOnly([
          'version',
          'usuario',
          'cantidadUbicaciones',
          'fechaCreacion',
          'ubicaciones',
        ]) &&
        request.resource.data.keys().hasAll([
          'version',
          'usuario',
          'cantidadUbicaciones',
          'fechaCreacion',
          'ubicaciones',
        ]) &&
        request.resource.data.version == 1 &&
        request.resource.data.usuario is string &&
        request.resource.data.usuario.size() <= 80 &&
        request.resource.data.cantidadUbicaciones is int &&
        request.resource.data.cantidadUbicaciones >= 1 &&
        request.resource.data.cantidadUbicaciones <= 200 &&
        request.resource.data.fechaCreacion == request.time &&
        request.resource.data.ubicaciones is list &&
        request.resource.data.ubicaciones.size() == request.resource.data.cantidadUbicaciones;
    }
  }
}
